# ============================================================
# vLLM 高併發推論部署 - 環境設定參考
# ============================================================
# 實際啟動腳本預設使用：
# - 單模型主服務：.env.interface
# - 多模型 Gateway：.env.API
#
# 此檔保留完整設定參考；不常改的推論行為、影片、文件、
# 溫度與懲罰預設值集中於 config/settings.py。

# ============================================================
# 🗂️  一、模型與快取設定
# ============================================================

# HuggingFace 緩存目錄（存放下載的模型檔案）
HF_CACHE_DIR=./AImodels

# 是否信任遠端 HuggingFace 程式碼（某些模型需要執行自訂程式碼）
TRUST_REMOTE_CODE=true

# ============================================================
# 🖥️  二、共用伺服器設定
# ============================================================

# API 伺服器綁定的主機 IP（127.0.0.1 = 本地，0.0.0.0 = 所有網卡）
API_HOST=127.0.0.1

# 單模型模式監聽端口；多模型模式會被 models.json 內各模型 api_port 覆寫
API_PORT=8000

# API 金鑰（⚠️ 生產環境必須更改）
API_KEY=Rushia_Secret_Key_Change_Me

# 單模型模式使用的模型；多模型模式由 models.json 管理
MODEL_NAME=./AImodels/Qwen3-14B-FP8

# ============================================================
# ⚙️  三、vLLM 引擎核心參數
# ============================================================

# 資料類型：auto（自動匹配 GPU）, float32, float16, bfloat16 等
DTYPE=auto

# 啟用前綴快取（加速重複請求，需更多顯存）
ENABLE_PREFIX_CACHING=true

# 禁用請求日誌（降低日誌開銷，大併發時建議開啟）
DISABLE_LOG_REQUESTS=false

# 禁用自訂 AllReduce（分散式訓練參數，通常保留預設）
DISABLE_CUSTOM_ALL_REDUCE=false

# 張量並行度（多 GPU 時提高此值以分散計算）
# 1 = 單 GPU，2 = 兩顆 GPU 以此類推
TENSOR_PARALLEL_SIZE=1

# 強制即時執行（禁用圖譜優化，CPU 記憶體充足時可降低顯存使用）
ENFORCE_EAGER=false

# 量化方法（留空 = 無量化，可選：awq, gptq, bitsandbytes 等）
QUANTIZATION=

# KV Cache 類型：fp8、auto；留空則由 vLLM 自動選擇
KV_CACHE_DTYPE=

# Speculative decoding 設定（JSON 字串）；留空則不傳入
SPECULATIVE_CONFIG=

# 非 MoE 層 NVFP4 GEMM backend（如 marlin）；留空則由 vLLM 自動選擇
VLLM_NVFP4_GEMM_BACKEND=

# 自動工具選擇（函數調用模型參數）
ENABLE_AUTO_TOOL_CHOICE=true

# 工具調用解析器（優先使用 qwen3_coder）
TOOL_CALL_PARSER=qwen3_coder

# 推理解析器（如 gemma4）；留空則不傳入
REASONING_PARSER=

# Chat template 路徑（Jinja2 格式）；留空則使用模型內建 template
CHAT_TEMPLATE=

# 多模態輸入上限（JSON 字串），例如 {"image": 5, "video": 1, "audio": 0}
LIMIT_MM_PER_PROMPT=

# MoE expert 層 backend（如 marlin）；留空則由 vLLM 自動選擇
MOE_BACKEND=

# 允許的本地媒體路徑（/ = 不限制）
ALLOWED_LOCAL_MEDIA_PATH=/

# ============================================================
# 📸 四、多媒體與推論行為參數
# ============================================================
# MAX_IMAGE_SIZE、VIDEO_FPS、DOCUMENT_MAX_TOKENS、DEFAULT_TEMPERATURE、
# DEFAULT_TOP_P、DEFAULT_REPETITION_PENALTY 等預設值已收斂到
# config/settings.py。只有部署時真的需要覆寫，才放到對應 env 檔。

# ============================================================
# 🔧 五、HuggingFace 與 CUDA 環境
# ============================================================

# 離線模式（0 = 連線，1 = 離線，需預先下載模型）
HF_HUB_OFFLINE=0

# 分詞器平行化（多進程時設為 false）
TOKENIZERS_PARALLELISM=false

# Triton PTXAS 編譯器路徑
TRITON_PTXAS_PATH=/usr/local/cuda/bin/ptxas

# CUDA 安裝路徑
CUDA_HOME=/usr/local/cuda

# Triton 快取目錄
TRITON_CACHE_DIR=/tmp/triton_cache

# ============================================================
# 🌐 六、Gateway 多模型管理設定
# ============================================================

# Gateway 伺服器綁定的主機 IP
GATEWAY_HOST=0.0.0.0

# Gateway 伺服器監聽端口
GATEWAY_PORT=3000

# Gateway 請求超時時間（秒）
GATEWAY_REQUEST_TIMEOUT=300

# Gateway 最大並行請求數
GATEWAY_MAX_INFLIGHT=48

# 預設模型別名（如未指定則使用）
GATEWAY_DEFAULT_MODEL=

# ============================================================
# 🎯 七、模型配置說明
# ============================================================
# 多模型配置現在使用 models.json 檔案管理
# 請參考專案根目錄的 models.json 範例：
# 
# [
#   {
#     "alias": "qwen-9b",
#     "model_name": "./AImodels/Qwen3.5-9B",
#     "api_port": 8101,
#     "max_model_len": 32768,
#     "gpu_memory_utilization": 0.15,
#     "max_num_seqs": 48,
#     "max_num_batched_tokens": 65536
#   }
# ]
# 
# 可配置的欄位：
# - alias: 模型別名（必填，用於 API 選擇）
# - model_name: 模型路徑或 HuggingFace 模型 ID（必填）
# - api_port: 該模型獨佔的 API 端口（必填）
# - max_model_len: 模型的最大序列長度（選填，預設 4096）
# - gpu_memory_utilization: GPU 顯存使用率 0.0-1.0（選填，預設 0.95）
# - max_num_seqs: 最大並行序列數（選填，預設 64）
# - max_num_batched_tokens: 最大批次 Token 數（選填，預設 8192）
# - tiktoken_encodings_base: tiktoken 編碼目錄（選填，某些模型需要）
# - dtype: 資料類型（選填，預設 auto）
# - tensor_parallel_size: 張量並行大小（選填，預設 1）
# - enforce_eager: 是否強制 eager 模式（選填）
# - enable_prefix_caching: 是否啟用前綴快取（選填）
# - disable_log_requests: 是否停用請求日誌（選填）
# - disable_custom_all_reduce: 是否停用自定義 all-reduce（選填）
# - quantization: 量化方法（選填，預設空）
# - kv_cache_dtype: KV Cache 類型（選填，預設空）
# - speculative_config: speculative decoding JSON 字串（選填，預設空）
# - vllm_nvfp4_gemm_backend: NVFP4 GEMM backend（選填，預設空）
# - allowed_local_media_path: 允許的本機媒體路徑（選填）
# - enable_auto_tool_choice: 是否啟用自動工具選擇（選填）
# - tool_call_parser: 工具呼叫解析器（選填，預設空）
# - reasoning_parser: 推理解析器（選填，預設空）
# - chat_template: Chat template 路徑（選填，預設空）
# - limit_mm_per_prompt: 多模態輸入上限 JSON 字串（選填，預設空）
# - moe_backend: MoE expert backend（選填，預設空）
# ============================================================
# 💡 常見場景調優指南
# ============================================================
# 1️⃣ 顯存不足 (OOM)：
#    - 降低 GPU_MEMORY_UTILIZATION（如 0.7）
#    - 降低 MAX_NUM_SEQS
#    - 調整 MAX_NUM_BATCHED_TOKENS
#
# 2️⃣ 延遲過高：
#    - 增加 GPU_MEMORY_UTILIZATION（如 0.95）
#    - 增加 MAX_NUM_SEQS
#    - 設定 TENSOR_PARALLEL_SIZE > 1（多 GPU）
#
# 3️⃣ 吞吐量低：
#    - 啟用 ENABLE_PREFIX_CACHING=true
#    - 增加 MAX_NUM_BATCHED_TOKENS
#    - 啟用 ENFORCE_EAGER=true（若 CPU 記憶體充足）
#
# 4️⃣ 視覺模型效能差：
#    - 檢查 config/settings.py 的 MAX_IMAGE_SIZE / VIDEO_* 預設是否合理
#    - 只有部署需要覆寫時才放入 .env.interface 或 .env.API
# ============================================================
