# LiteLLM is an independent Compose project. Copy this file to .env in this
# directory; never add these values to the root Campus .env or commit them.
#
# Generate independent random values, for example:
# python -c "import secrets; print(secrets.token_urlsafe(48))"
LITELLM_MASTER_KEY=replace-with-an-isolated-staging-master-key
# Bearer key LiteLLM sends to each local vLLM /v1 endpoint. Set this to the
# same secret as API_KEY in .env.API; it is separate only because Docker
# injects it into the LiteLLM container.
VLLM_UPSTREAM_API_KEY=replace-with-the-vllm-api-key-from-.env.API

# Production LiteLLM state must use a dedicated database and role. The Campus
# application database is not a valid target. On this host, the main Compose
# PostgreSQL port is normally bound to 127.0.0.1:5433.
DATABASE_URL=postgresql://litellm:replace-with-db-password@127.0.0.1:5433/litellm
LITELLM_SALT_KEY=replace-with-an-immutable-random-salt-key
