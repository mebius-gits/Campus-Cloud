# Phase 2 staging-only LiteLLM secrets. Copy these values into the root .env
# of the multi-model host; never commit the resulting .env file.
#
# Generate independent random values, for example:
# python -c "import secrets; print(secrets.token_urlsafe(48))"
LITELLM_MASTER_KEY=replace-with-an-isolated-staging-master-key
# Bearer key LiteLLM sends to each local vLLM /v1 endpoint. Set this to the
# same secret as API_KEY in .env.API; it is separate only because Docker
# injects it into the LiteLLM container.
VLLM_UPSTREAM_API_KEY=replace-with-the-vllm-api-key-from-.env.API

# Used only by the Campus admin runtime-snapshot endpoint in Phase 2. It must
# equal the isolated staging master key above. Do not introduce this variable
# in production; Phase 4 uses a dedicated restricted management identity.
LITELLM_RUNTIME_API_KEY=replace-with-the-isolated-staging-master-key
LITELLM_RUNTIME_BASE_URL=http://host.docker.internal:4000
