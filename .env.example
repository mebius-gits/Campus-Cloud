# =============================================================================
# SkyLab 部署設定 —— 部署只需要這一個檔案
#
#   cp .env.example .env
#   # 改好下面【1】【2】兩區，其餘多半保持預設即可
#   docker compose up -d --build
#
# 變數名已對齊後端實際讀取的設定（core/config.py、features/ai、ai/*）。
# 註解掉或留空的項目代表「有合理預設、通常不用設」。
# =============================================================================

# -----------------------------------------------------------------------------
# 【1】必改 —— 身分與密鑰（正式對外務必修改）
# -----------------------------------------------------------------------------
# 產生：python -c "import secrets; print(secrets.token_urlsafe(32))"
SECRET_KEY=changethis
# 第一位管理員帳號（登入後在「管理員介面」設定 Proxmox 連線，連線資訊存資料庫）
FIRST_SUPERUSER=admin@example.com
FIRST_SUPERUSER_PASSWORD=changethis
# 資料庫密碼（容器內 PostgreSQL 會用這個值建立）
POSTGRES_PASSWORD=changethis

# -----------------------------------------------------------------------------
# 【2】環境
# -----------------------------------------------------------------------------
# local / staging / production。
# 設 production 時，上面三個密鑰若仍是 "changethis" 會直接啟動失敗（安全檢查）。
ENVIRONMENT=local
ENABLE_SIGNUP=true
PROJECT_NAME=SkyLab
# 後端寄信時產生的前端連結位址（沒用到 email 可不管；nginx 同源下前端會自動跟著訪問網址走）
FRONTEND_HOST=http://localhost

# -----------------------------------------------------------------------------
# 【3】資料庫（容器內 PostgreSQL，通常保持預設）
# -----------------------------------------------------------------------------
# 容器內固定連服務名 db（docker-compose 會強制覆蓋為 db），請勿改成外部 IP
POSTGRES_SERVER=db
POSTGRES_PORT=5432
POSTGRES_DB=app
POSTGRES_USER=postgres

# -----------------------------------------------------------------------------
# 【4】Compose 內部用（保持預設即可）
# -----------------------------------------------------------------------------
# 後端不讀 DOMAIN / STACK_NAME，目前僅 docker-compose 殘留的標籤需要
DOMAIN=localhost
STACK_NAME=SkyLab
# 本地 build 的映像名稱
DOCKER_IMAGE_BACKEND=backend
DOCKER_IMAGE_FRONTEND=frontend

# -----------------------------------------------------------------------------
# 【5】Redis（速率限制 / JTI 撤銷 / 排程器）
# -----------------------------------------------------------------------------
# 容器部署建議 true；容器內 URL 用服務名 redis
REDIS_ENABLED=true
REDIS_URL=redis://redis:6379/0

# -----------------------------------------------------------------------------
# 【6】CORS（nginx 同源時可留空；前後端不同網域才需要列來源）
# -----------------------------------------------------------------------------
BACKEND_CORS_ORIGINS=

# -----------------------------------------------------------------------------
# 【7】Proxmox 連線（選填）
#   實際連線在「管理員介面」設定並加密存進資料庫，這裡通常不用填。
#   下列為後端啟動時的 fallback 預設，需要時再取消註解。
# -----------------------------------------------------------------------------
# PROXMOX_HOST=
# PROXMOX_USER=
# PROXMOX_PASSWORD=
# PROXMOX_VERIFY_SSL=false

# -----------------------------------------------------------------------------
# 【8】System AI / vLLM（選填；不用 AI 功能保持預設即可）
#   只有這三個從 env 讀；temperature / max_tokens 等細節在 backend/config/system-ai.json
# -----------------------------------------------------------------------------
VLLM_BASE_URL=http://localhost:8000/v1
VLLM_API_KEY=vllm-secret-key-change-me
VLLM_MODEL_NAME=

# -----------------------------------------------------------------------------
# 【9】AI API Gateway 代理（選填）
# -----------------------------------------------------------------------------
AI_API_BASE_URL=http://localhost:3000
AI_API_API_KEY=ai-api-secret-key-change-me
AI_API_TIMEOUT=120
AI_API_RATE_LIMIT_PER_MINUTE=20
AI_API_RATE_LIMIT_WINDOW_SECONDS=60
AI_API_PUBLIC_BASE_URL=http://localhost:8000

# -----------------------------------------------------------------------------
# 【10】SSH 遠端執行 / PVE log collector（選填）
# -----------------------------------------------------------------------------
SSH_INSECURE_HOST_KEY=true
SSH_DEFAULT_USER=root
SSH_TIMEOUT=30

# -----------------------------------------------------------------------------
# 【11】Email / SMTP（選填；不設則停用寄信）
# -----------------------------------------------------------------------------
SMTP_HOST=
SMTP_USER=
SMTP_PASSWORD=
SMTP_PORT=587
SMTP_TLS=True
SMTP_SSL=False
EMAILS_FROM_EMAIL=

# -----------------------------------------------------------------------------
# 【12】其他選填
# -----------------------------------------------------------------------------
# Google OAuth 登入
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
# Sentry 錯誤追蹤
SENTRY_DSN=
# Desktop client / frp tunnel
# DESKTOP_CLIENT_BACKEND_URL=http://localhost:8000
# DESKTOP_CLIENT_DOWNLOAD_URL=
# FRP_SERVER_ADDR=
# FRP_SERVER_PORT=7000
# FRP_TOKEN=
# Logging（容器建議 LOG_JSON=true）
LOG_LEVEL=INFO
LOG_JSON=true
LOG_FILE_ENABLED=true
